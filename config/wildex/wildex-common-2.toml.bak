[general]
	#Enable Hidden Mode: mobs are hidden until discovered by killing or spying
	hiddenMode = true
	#Require the Wildex book in the inventory to use the keybind
	requireBookForKeybind = true
	#Give the Wildex book once per player when they join a world for the first time.
	giveBookOnFirstJoin = false
	#Ticks required to discover a mob while continuously aiming with a Spyglass.
	# Default: 28
	# Range: 1 ~ 200
	spyglassDiscoveryChargeTicks = 28
	#Grant XP for newly discovered Wildex entries when they are marked as viewed.
	newEntryRewardsXp = true
	#XP points granted per newly discovered Wildex entry.
	# Default: 5
	# Range: > 0
	newEntryXpAmount = 5
	#If true, a player that already completed Wildex stays complete even when new mobs are added later.
	#If false, completion is re-evaluated against the current total mob count.
	keepCompletionAfterNewMobs = false

[wildexList]
	#Entries to exclude from Wildex.
	#- Use a namespace to exclude an entire mod (e.g. "alexsmobs").
	#- Use a full entity id to exclude a specific mob (e.g. "alexsmobs:grizzly_bear").
	#Applies to UI + discovery + completion.
	#
	excludedModIds = []

[multiplayer]
	#Enable the Wildex entry share-offer UI in the mob details panel.
	shareOffersEnabled = true
	#Enable optional price input for share offers.
	shareOffersPaymentEnabled = true
	#Currency item id used for share offers (single item type, e.g. minecraft:emerald).
	shareOfferCurrencyItem = "minecraft:emerald"
	#Maximum allowed price value for share offers.
	# Default: 64
	# Range: > 0
	shareOfferMaxPrice = 64

[integrationDebug]
	#Enable Wildex KubeJS bridge emits (discovery/completed).
	#Keep this enabled for normal use.
	#Disable only for troubleshooting or if a modpack/addon has compatibility issues with KubeJS event handling.
	#
	kubejsBridgeEnabled = true
	#Enable mob discovery from Exposure photo frames.
	#Only applies when Exposure is installed.
	exposureDiscoveryEnabled = true
	#Enable Debug Mode: allows manual discovery of mobs via UI (hidden mode only)
	debugMode = false
